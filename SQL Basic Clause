-- membuat tabel menggunakan SQL

--'BUAT TABEL konsumen' 
CREATE TABLE konsumen (
  -- mention nama-nama kolom dan tipe data
  -- syntax (nama_kolom tipe_data)
  cust_id INT,
  nama VARCHAR(64),
  alamat VARCHAR(128),
  no_hp VARCHAR(13),
  tanggal_join DATE
  )
  
  -- block query yang akan di running, lalu klik run (1x)
  -- lalu cek di bagian 'Table'
  
  -- alternatif
  CREATE TABLE konsumen (cust_id INT,nama VARCHAR(64),alamat VARCHAR(128),no_hp VARCHAR(13),tanggal_join DATE) 
  
  -- memasukkan nilai ke dalam tabel 
  -- query: MASUKKAN KE DALAM konsumen NILAI_NILAI <berikut/data yang diinput> 
  
  INSERT INTO -- commandnya bisa huruf kecil 
  	konsumen
  VALUES
  	(1,'Abdi','Bojongsoang','08112345','2024-04-03'),
    (2,'Budi','Nagreg','08112346','2023-04-03'),
    (3,'Cinta','Dago','08112347','2023-04-01')
    
