-- tolong ambilkan data transaksi yang berasal dari kota 'Lowell' dan 'Providence'
select * from `tokouswah.orders` where city = 'Lowell' and city = 'Providence' 

select * from `tokouswah.orders` where city = 'Lowell' or city = 'Providence' 

-- transaksi selain di kota Lowell
select * from `tokouswah.orders` where not city = 'Lowell'

-- region, category
-- east AND office supplies
-- OR
-- west AND technology
-- tampilkan dalam satu tabel

select * from `tokouswah.orders`
where
   region = 'East' AND category = 'Office Supplies' OR region = 'West' AND category = 'Technology'

-- vs

select * from `tokouswah.orders`
where
  (region = 'East' AND category = 'Office Supplies')
  OR 
  (region = 'West' AND category = 'Technology')

-- IN
select * from `tokouswah.orders` where city = 'Lowell' or city = 'Providence'

select * from `tokouswah.orders` where city IN ('Lowell','Providence')
-- PILIH semua kolom DARI tabel orders YANG MANA kota nya berada DI DALAM (list kota)
